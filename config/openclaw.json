{
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "mode": "local",
    "trustedProxies": ["0.0.0.0/0"],
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowedOrigins": ["https://alaska-openclaw-production.up.railway.app"],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "streaming": false,
      "nativeStreaming": false
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true
    }
  }
}
