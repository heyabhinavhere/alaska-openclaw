# ============================================
# Alaska — AI Project Manager — Environment Variables
# ============================================
# Set these in Railway's Variables tab (NOT in this file).
# This file is a reference template only.
# DO NOT commit a .env file to git — it contains secrets.
# ============================================

# --- Required: AI Brain ---
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (console.anthropic.com)

# --- Required: OpenClaw ---
OPENCLAW_GATEWAY_TOKEN=...            # Password for the admin dashboard
SETUP_PASSWORD=...                    # Password for the setup/onboarding page

# --- Required: Notion ---
NOTION_API_KEY=ntn_...                # Notion internal integration key (notion.so/profile/integrations)

# --- Required: Slack ---
SLACK_BOT_TOKEN=xoxb-...             # Slack bot token (api.slack.com/apps → OAuth)
SLACK_APP_TOKEN=xapp-...             # Slack app token (api.slack.com/apps → Basic Info → App-Level Tokens)

# --- Required: Meeting Transcripts ---
FIREFLIES_API_KEY=...                 # Fireflies GraphQL API key (app.fireflies.ai/settings → Developer)

# --- Required: Product Analytics ---
AMPLITUDE_API_KEY=...                 # Amplitude API key (amplitude.com → Settings → Projects)
AMPLITUDE_SECRET_KEY=...              # Amplitude secret key (same place, required for HTTP API)

# --- Required: Customer Engagement ---
CUSTOMERIO_SITE_ID=...                # Customer.io Site ID (fly.customer.io → Settings → API Credentials)
CUSTOMERIO_TRACK_API_KEY=...          # Customer.io Track API key (Journeys Track API)
CUSTOMERIO_APP_API_KEY=...            # Customer.io App API key (Bearer token for /v1/ endpoints)

# --- Required: GitHub Activity ---
BON_GITHUB_TOKEN=ghp_...              # GitHub PAT, repo:read for follow-through commit checks (renamed from GITHUB_TOKEN — OpenClaw ≥5.28 strips GITHUB_TOKEN from sessions, #149)

# --- Optional: native memory search (OpenClaw memorySearch, provider=openai) ---
OPENAI_API_KEY=sk-...                 # embedding key for semantic recall over MEMORY.md + memory/*.md; NOT stripped by 5.28. Absent → memory search stays dark (no crash).

# --- Required: BON Backend (user-profile-360 skill) ---
BON_API_BASE_URL=https://agentic-dev.boncredit.ai   # BON admin API base (swap to prod URL at cutover)
BON_ADMIN_API_KEY=...                 # X-Admin-Key for /api/admin/users/* — rotate regularly, store in Railway only

# --- Required: Webhook Auth ---
HOOKS_TOKEN=...                       # Random secret; substituted into openclaw.json by entrypoint.sh
                                      # Used to authenticate Fireflies webhook → /hooks/fireflies

# --- System (don't change) ---
PORT=8080
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
INTERNAL_GATEWAY_HOST=127.0.0.1
INTERNAL_GATEWAY_PORT=18789
ENABLE_WEB_TUI=true
RAILWAY_RUN_UID=0
